  var1 = "TP53", var1_modal = "Mutation", var1_cancers = "BRCA-Basal",
  analysis_type = "enrichment"
)

# Find subtype-specific pathways
luma_only <- setdiff(luma_result$stats$pathway, basal_result$stats$pathway)
}

